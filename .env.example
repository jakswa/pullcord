# MARTA GTFS-RT API key
# Get one from MARTA's developer portal.
MARTA_API_KEY=

# Local server port
PORT=4200

# Web Push VAPID keys (required for "Pull the Cord" notifications)
# Generate with: bun x web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com
